# Vega Chat — 环境变量模板
# 复制为 docker/.env 并填好下面标 <...> 的值。绝不要把真 .env 提交进 git。
# 生成随机密钥: openssl rand -hex 32

# ── 站点 ──
APP_TITLE=Vega Chat
CUSTOM_FOOTER=Vega Chat · 多模型聊天
HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=https://chat.example.com
DOMAIN_SERVER=https://chat.example.com
HELP_AND_FAQ_URL=https://example.com/
NO_INDEX=true
TRUST_PROXY=1
CONFIG_PATH=/app/librechat.yaml

# ── 数据库 / 搜索 ──
MONGO_URI=mongodb://mongodb:27017/LibreChat
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=<openssl rand -hex 32>
MEILI_NO_ANALYTICS=true
SEARCH=true

# ── RAG 向量库 (pgvector) ──
# 仅本机 docker 网络内互访, 不对外暴露; 仍建议改掉默认密码
POSTGRES_DB=mydatabase
POSTGRES_USER=myuser
POSTGRES_PASSWORD=<改成你自己的强密码>
RAG_PORT=8000

# ── 密钥 (务必各自生成随机值) ──
JWT_SECRET=<openssl rand -hex 32>
JWT_REFRESH_SECRET=<openssl rand -hex 32>
CREDS_KEY=<openssl rand -hex 32>
CREDS_IV=<openssl rand -hex 16>
ADMIN_SESSION_SECRET=<openssl rand -hex 32>

# ── 模型 provider key (按需填, 没有就留空并在 librechat.yaml 关掉该 endpoint) ──
OPENAI_API_KEY=<可选>
ANTHROPIC_API_KEY=<可选>
DEEPSEEK_API_KEY=<可选>
ENDPOINTS=openAI,anthropic,custom

# ── 注册 / 登录 ──
ALLOW_REGISTRATION=true
ALLOW_EMAIL_LOGIN=true
ALLOW_PASSWORD_RESET=false
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false
ALLOW_UNVERIFIED_EMAIL_LOGIN=true

# ── 限流 / 余额 ──
CHECK_BALANCE=false
CONCURRENT_MESSAGE_MAX=2
LIMIT_CONCURRENT_MESSAGES=true
LIMIT_MESSAGE_IP=true
LIMIT_MESSAGE_USER=false
MESSAGE_IP_MAX=40
MESSAGE_IP_WINDOW=1
MESSAGE_USER_MAX=40
MESSAGE_USER_WINDOW=1

# ── 文件 / 日志 ──
FILE_UPLOAD_PATH=/app/uploads
CONSOLE_JSON=false
DEBUG_CONSOLE=false
DEBUG_LOGGING=false
